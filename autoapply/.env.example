# ─── AI Provider ─────────────────────────────────────────────────────────────
# Choose your LLM provider: "anthropic" (recommended) or "groq" (free)
LLM_PROVIDER=anthropic

# Anthropic Claude — https://console.anthropic.com (required if LLM_PROVIDER=anthropic)
ANTHROPIC_API_KEY=sk-ant-...
# Optional: override the default model
# ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Groq — https://console.groq.com (required if LLM_PROVIDER=groq, free tier available)
# GROQ_API_KEY=gsk_...
# Optional: override the default model
# GROQ_MODEL=llama-3.3-70b-versatile

# ─── Database ────────────────────────────────────────────────────────────────
# Choose a strong password — this must match POSTGRES_PASSWORD below
DATABASE_URL=postgresql+asyncpg://autoapply:CHANGE_ME@postgres:5432/autoapply
# Sync URL used by Alembic migrations
SYNC_DATABASE_URL=postgresql://autoapply:CHANGE_ME@postgres:5432/autoapply
POSTGRES_PASSWORD=CHANGE_ME

# ─── Redis / Celery ──────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ─── Clerk Auth ──────────────────────────────────────────────────────────────
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
CLERK_WEBHOOK_SECRET=whsec_...

# ─── App ─────────────────────────────────────────────────────────────────────
ENVIRONMENT=development
NEXT_PUBLIC_API_URL=http://localhost:8000

# ─── Storage ─────────────────────────────────────────────────────────────────
# Local path inside container; set to S3/R2 URL for cloud deployment
UPLOADS_DIR=/app/uploads
