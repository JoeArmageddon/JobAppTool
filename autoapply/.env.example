# ─── Anthropic ───────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ─── Database ────────────────────────────────────────────────────────────────
# Async URL used by FastAPI/SQLAlchemy
DATABASE_URL=postgresql+asyncpg://autoapply:autoapply_dev@postgres:5432/autoapply
# Sync URL used by Alembic migrations
SYNC_DATABASE_URL=postgresql://autoapply:autoapply_dev@postgres:5432/autoapply
POSTGRES_PASSWORD=autoapply_dev

# ─── Redis / Celery ──────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ─── Clerk Auth ──────────────────────────────────────────────────────────────
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
CLERK_WEBHOOK_SECRET=whsec_...

# ─── App ─────────────────────────────────────────────────────────────────────
ENVIRONMENT=development
NEXT_PUBLIC_API_URL=http://localhost:8000

# ─── Storage ─────────────────────────────────────────────────────────────────
# Local path inside container; set to S3/R2 URL for cloud deployment
UPLOADS_DIR=/app/uploads
